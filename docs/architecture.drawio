<mxfile host="app.diagrams.net">
  <diagram name="HLD - SMS Gateway" id="hld-sms-gateway">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="n1" value="Client&#10;درخواست‌های REST می‌فرسته" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="305" y="40" width="240" height="70" as="geometry" />
        </mxCell>

        <mxCell id="n2" value="API layer (Gin)&#10;اعتبارسنجی ورودی و قیمت" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="305" y="150" width="240" height="70" as="geometry" />
        </mxCell>

