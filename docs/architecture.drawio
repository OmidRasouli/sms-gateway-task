        <mxCell id="n6" value="Operator (mock)&#10;گیت‌وی تلکام خارجی" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="305" y="590" width="240" height="70" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="n1" target="n2">
