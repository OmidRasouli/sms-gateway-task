        <mxCell id="n5" value="Worker pool&#10;ارسال به اپراتور و آپدیت وضعیت" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="305" y="480" width="240" height="70" as="geometry" />
