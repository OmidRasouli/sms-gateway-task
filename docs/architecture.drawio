        <mxCell id="note1" value="مسیر گزارش‌گیری (GET /messages, GET /balance) مستقیم از PostgreSQL می‌خونه، بدون عبور از صف" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
