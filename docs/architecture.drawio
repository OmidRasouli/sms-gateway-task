        <mxCell id="n4" value="Asynq queue (Redis)&#10;صف اکسپرس و عادی" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="305" y="370" width="240" height="70" as="geometry" />
