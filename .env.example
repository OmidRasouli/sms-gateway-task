# HTTP API
PORT=8080

# PostgreSQL
DATABASE_URL=postgres://sms:sms@localhost:5432/sms_gateway?sslmode=disable

# Kafka
KAFKA_BROKERS=localhost:9092

# Worker concurrency
EXPRESS_CONCURRENCY=15
NORMAL_CONCURRENCY=10

# Price cache
PRICE_CACHE_REFRESH_INTERVAL=5m

# Delivery retries before DLQ
MAX_RETRY_ATTEMPTS=3
